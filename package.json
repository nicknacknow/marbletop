{
  "name": "marble_project",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "marble/*"
  ],
  "description": "",
  "main": "index.js",
  "scripts": {
    "protocol:compile": "npm run compile -w @marble/protocol",
    "protocol:test": "npm run test -w @marble/protocol",
    "protocol:deploy:local": "npm run deploy:local -w @marble/protocol",
    "protocol:workspace": "npm run workspace -w @marble/protocol",
    "protocol:node": "npm run node -w @marble/protocol",
    
    "protocol": "concurrently -n node,deploy \"npm run protocol:node\" \"wait-on tcp:127.0.0.1:8545 && npm run protocol:deploy:local\"",
    "frontend": "npm start -w @marble/frontend",
    "backend": "npm start -w @marble/backend"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "concurrently": "^9.2.0",
    "wait-on": "^8.0.1"
  }
}